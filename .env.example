# Google AI Studio — create an API key at https://aistudio.google.com/apikey
# Used by @google/generative-ai and most Gemini quickstarts.
# Required for real POST /api/generate (not needed for vitest mocks).
GEMINI_API_KEY=

# If you use Vercel AI SDK (@ai-sdk/google), set the same key here instead
# (or duplicate the value in both vars if your code reads both).
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional — defaults can live in code instead (see lib/generator.ts)
# gemini-2.0-flash is deprecated for new API keys; default is gemini-2.5-flash
# GEMINI_MODEL_MAIN=gemini-2.5-flash
# GEMINI_MODEL_CHEAP=gemini-2.5-flash

APIFY_API_TOKEN=
APIFY_WEBHOOK_SECRET=

# Supabase full-cutover (recommended for production/reviewer links).
# When both vars are set, Node API uses Supabase instead of local SQLite.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — same SQLite file for Next.js (lib/db.ts) and Python (ingestion/paths.py).
# Default when unset: data/corpus.db under the project root.
# CORPUS_DB_PATH=data/corpus.db