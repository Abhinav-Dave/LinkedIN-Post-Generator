# Google AI Studio — create an API key at https://aistudio.google.com/apikey
# Used by @google/generative-ai and most Gemini quickstarts.
GEMINI_API_KEY=

# If you use Vercel AI SDK (@ai-sdk/google), set the same key here instead
# (or duplicate the value in both vars if your code reads both).
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional — defaults can live in code instead
# GEMINI_MODEL_MAIN=gemini-2.0-flash
# GEMINI_MODEL_CHEAP=gemini-2.0-flash

APIFY_API_TOKEN=
APIFY_WEBHOOK_SECRET=